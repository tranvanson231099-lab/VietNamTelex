{
  "manifest_version": 3,
  "name": "Vietnamese AI IME",
  "version": "2.0",
  "description": "Telex + AI suggestion",

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["input"],

  "input_components": [
    {
      "name": "Vietnamese AI",
      "type": "ime",
      "id": "vn_ai_ime",
      "description": "AI Vietnamese Input",
      "language": "vi",
      "layouts": ["us"]
    }
  ]
}